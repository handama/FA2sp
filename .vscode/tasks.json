{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Restore and Build (Debug)",
            "type": "shell",
            "command": "msbuild",
            "args": [
                "${workspaceFolder}/FA2sp.sln",
                "/t:Restore,Build", 
                "/p:Configuration=Debug",
                "/p:Platform=x86",
                "/m"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile",
            "detail": "Restore NuGet package and build Debug configuration"
        },
        {
            "label": "Restore and Build (Release)",
            "type": "shell",
            "command": "msbuild",
            "args": [
                "${workspaceFolder}/FA2sp.sln",
                "/t:Restore,Build",
                "/p:Configuration=Release",
                "/p:Platform=x86",
                "/m"
            ],
            "group": "build",
            "problemMatcher": "$msCompile",
            "detail": "Restore NuGet package and build Release configuration"
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "msbuild",
            "args": [
                "${workspaceFolder}/FA2sp.sln",
                "/t:Clean",
                "/p:Configuration=Debug",
                "/p:Platform=x86"
            ],
            "problemMatcher": [],
            "detail": "Clean Debug build"
        }
    ]
}