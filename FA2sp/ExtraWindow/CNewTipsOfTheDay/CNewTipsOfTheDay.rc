#include "Windows.h"

335 DIALOG 0, 0, 275, 174
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Tip of the day"
LANGUAGE LANG_GERMAN, SUBLANG_GERMAN
FONT 8, "Tahoma"
{
   CONTROL "Did you know...", 1002, STATIC, SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 49, 17, 69, 23 
   CONTROL "TIP", 1004, EDIT, ES_LEFT | ES_MULTILINE | ES_READONLY | WS_CHILD | WS_VISIBLE | WS_BORDER | WS_VSCROLL, 10, 48, 256, 95 
   CONTROL "Next tip", 1, BUTTON, BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 164, 152, 50, 14 
   CONTROL "Close", 2, BUTTON, BS_DEFPUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 218, 152, 50, 14 
   CONTROL "Show tips at program start", 1001, BUTTON, BS_AUTOCHECKBOX | BS_MULTILINE | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 9, 150, 102, 19 
   CONTROL "", 1000, STATIC, SS_BITMAP | WS_CHILD | WS_VISIBLE, 10, 8, 35, 39 
   CONTROL "Previous tip", 1005, BUTTON, BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 110, 152, 50, 14 
}
